  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644f519d744bd0543a105d2f20035f34, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogManager
  background: {fileID: 1851023764}
  characterImage: {fileID: 0}
  dialogText: {fileID: 1722191617}
  speakerName: {fileID: 2051113581}
  continuePrompt: {fileID: 221223826}
  dialogBox: {fileID: 1536829573}
  flashOverlay: {fileID: 212693576}
  audioSource: {fileID: 1417414763}
  whooshSFX: {fileID: 8300000, guid: 976f9e504a41126439b2f3cf4f0d39e2, type: 3}
  noiseSFX: {fileID: 8300000, guid: e2ed0bd8e598f974e91b6f5994e54585, type: 3}
  noiseStartLine: 7
  noiseEndLine: 9
  flashAtLine: 0
  flashDuration: 2
  dialogLines:
  - speakerName: 
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: Cahaya membentuk makhluk kecil
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: '"Akhirnya... seseorang mendengarkannya."'
  - speakerName: Aksa
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: '"SIAPA KAMU?!"'
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: '"Hai, aku Ranu, penjaga harmoni Nusantara."'
  - speakerName: Aksa
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: '"...harmoni?"'
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: '"Iya, harmoni nusantara, tetapi musik tradisional Indonesia sekarang
      sudah mulai dilupakan."'
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: '"Jika ini terus terjadi, harmoni nusantara akan hilang."'
  - speakerName: Aksa
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: '"Terus... aku harus apa?"'
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: '"Pergilah ke daerah-daerah yang akan aku tunjukkan."'
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: '"Pelajari iramanya."'
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 98128b313f6718b468e3a7bfcba3a270, type: 3}
    characterSprite: {fileID: 0}
    dialogText: '"Dan bangkitkan kembali harmoninya."'
  typingSpeed: 0.03
  nextSceneName: LevelSelectScene
