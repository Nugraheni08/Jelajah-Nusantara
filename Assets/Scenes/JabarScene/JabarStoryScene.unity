  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MalukuDialogManager
  background: {fileID: 964099350}
  characterImageLeft: {fileID: 1700124915}
  characterImageRight: {fileID: 473883671}
  dialogText: {fileID: 58804912}
  speakerName: {fileID: 528276943}
  continuePrompt: {fileID: 968068045}
  dialogBox: {fileID: 2040031904}
  flashOverlay: {fileID: 0}
  misiPanel: {fileID: 1279407348}
  misiTitle: {fileID: 539808342}
  misiDesc: {fileID: 1924856441}
  misiButton: {fileID: 1465953582}
  darkOverlay: {fileID: 161076378}
  countdownPanel: {fileID: 0}
  countdownText: {fileID: 0}
  audioSource: {fileID: 0}
  noiseSFX: {fileID: 0}
  noiseStartLine: 3
  noiseEndLine: 4
  flashAtLine: 999
  flashDuration: 1.5
  dialogLines:
  - speakerName: 
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 0}
    dialogText: Daerah pertama terbuka
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 21300000, guid: 36be9fd75333f054ba379df920bdd0d8, type: 3}
    dialogText: Dengarkan suara angklung.
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 21300000, guid: 36be9fd75333f054ba379df920bdd0d8, type: 3}
    dialogText: Ikuti ritmenya.
  - speakerName: Aksa
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 21300000, guid: f767207bafc60a04a8793df135644b91, type: 3}
    characterSpriteRight: {fileID: 0}
    dialogText: 'Jadi aku harus memainkan musik ini?

'
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 21300000, guid: 36be9fd75333f054ba379df920bdd0d8, type: 3}
    dialogText: Benar.
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 21300000, guid: 36be9fd75333f054ba379df920bdd0d8, type: 3}
    dialogText: Setiap daerah memiliki harmoni yang berbeda.
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 21300000, guid: d0d890fc77fb9524c8f969c917670a5f, type: 3}
    dialogText: Jika kamu dapat mengikuti iramanya, kekuatan harmoni akan bangkit
      kembali
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 21300000, guid: d0d890fc77fb9524c8f969c917670a5f, type: 3}
    dialogText: Bagus. Sekarang saatnya misi yang sebenarnya.
  - speakerName: Aksa
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 21300000, guid: 21de816aa8ae34043a5c97738347ede4, type: 3}
    dialogText: Apa itu?
  - speakerName: 
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 21300000, guid: 68426ea8f19c7a64d8e8e1288308566b, type: 3}
    dialogText: 
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 21300000, guid: 78a1c13d632bf9746908c46d3c4f2e8c, type: 3}
    dialogText: Noise.
  - speakerName: Ranu
    background: {fileID: 21300000, guid: 7296b834f9aa5124c993d0a73015b837, type: 3}
    characterSpriteLeft: {fileID: 0}
    characterSpriteRight: {fileID: 21300000, guid: 78a1c13d632bf9746908c46d3c4f2e8c, type: 3}
    dialogText: Kalahkan dia dan pulihkan harmoni angklung
  typingSpeed: 0.03
  gameplaySceneName: GamePlayScene
  levelDataKey: LevelData_Jabar
